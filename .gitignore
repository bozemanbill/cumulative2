# History files
.Rhistory
.Rapp.history

# Session Data files
.RData
.RDataTmp

# User-specific files
.Ruserdata

# Example code in package build process
*-Ex.R

# Output files from R CMD build / check
/*.tar.gz
/*.Rcheck/

# RStudio files
.Rproj.user/

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# renv library (uncomment if you adopt renv later)
# renv/library/
# renv/local/
# renv/cellar/

# Knitted output (uncomment to keep rendered HTML out of version control)
# *.html

# OS / editor cruft
.DS_Store
Thumbs.db
*~
.vscode/
